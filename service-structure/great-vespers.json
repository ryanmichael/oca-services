{
  "_meta": {
    "service": "great-vespers",
    "description": "Great Vespers — served every Saturday evening and on any evening when the Menaion or Pentecostarion appoints OT/NT lessons",
    "source": "OCA Office of Vespers, 2021-11-19",
    "version": "0.1.0"
  },

  "sections": [

    {
      "id": "opening",
      "label": "Opening",
      "note": "If Ninth Hour was said immediately prior, begin at 'Come, let us worship…' skipping to psalm103-intro",
      "blocks": [
        {
          "id": "opening-exclamation",
          "type": "fixed",
          "speaker": "priest",
          "textKey": "opening.exclamation"
        },
        {
          "id": "opening-amen",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "opening.amen"
        },
        {
          "id": "heavenly-king",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "prayers.heavenlyKing"
        },
        {
