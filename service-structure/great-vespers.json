          "textKey": "doxology.gloryNow"
        },
        {
          "id": "our-father",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "prayers.ourFather"
        },
        {
          "id": "kingdom-exclamation",
          "type": "fixed",
          "speaker": "priest",
          "textKey": "prayers.ourFather.doxology"
        },
        {
          "id": "lord-have-mercy-12",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "responses.lordHaveMercyTwelve"
        },
        {
          "id": "glory-now-short-3",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "doxology.gloryNow"
        }
      ]
    },

    {
      "id": "psalm103",
      "label": "Psalm 103 (104)",
      "blocks": [
        {
          "id": "psalm103-intro",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "psalm103.intro"
        },
        {
          "id": "psalm103-body",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "psalm103.body"
        },
        {
          "id": "psalm103-refrain",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "psalm103.refrain",
          "note": "Repeated verses sung after the full psalm"
        },
        {
          "id": "psalm103-close",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "psalm103.close"
        },
        {
          "id": "alleluia-3",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "responses.alleluiaThrice"
        }
      ]
    },

    {
      "id": "great-litany",
      "label": "The Peace Litany",
      "note": "Deacon leads; priest if no deacon",
      "blocks": [
        {
          "id": "great-litany-body",
          "type": "fixed",
          "speaker": "deacon",
          "textKey": "litanies.great"
        },
        {
          "id": "great-litany-exclamation",
          "type": "fixed",
          "speaker": "priest",
          "textKey": "litanies.great.exclamation"
        }
      ]
    },

    {
      "id": "kathisma",
      "label": "Kathisma",
      "note": "At Great Vespers, the first section of Kathisma 1 (Blessed is the Man) is sung, with exceptions",
      "blocks": [
        {
          "id": "kathisma-text",
          "type": "variable",
          "slot": "kathisma",
          "resolvedBy": "kathismaResolver",
          "conditions": [
            {
              "when": "greatVespers.saturday",
              "except": [
                "eveOfGreatFeastOfLord",
                "kathismaIsAbsent"
              ],
              "use": "kathisma1.section1"
            },
            {
              "when": "greatVespers.otherEvenings",
              "use": "kathisma1.section1",
              "note": "Omitted on eves of great feasts of the Lord, except Sat/Sun evening"
            }
          ]
        }
      ]
    },

    {
      "id": "little-litany-1",
      "label": "Little Litany",
      "note": "Said at conclusion of kathisma",
      "blocks": [
        {
          "id": "little-litany-body",
          "type": "fixed",
          "speaker": "deacon",
          "textKey": "litanies.little"
        },
        {
          "id": "little-litany-exclamation",
          "type": "fixed",
          "speaker": "priest",
          "textKey": "litanies.little.exclamation1"
        }
      ]
    },

    {
      "id": "lord-i-call",
      "label": "Lord, I Have Cried",
      "note": "Choir begins in the tone of the first sticheron. Reader reads psalm verses between stichera.",
      "blocks": [
        {
          "id": "lord-i-call-refrain",
          "type": "fixed",
          "speaker": "choir",
          "textKey": "lordICall.refrain"
        },
        {
          "id": "lord-i-call-psalms",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "lordICall.psalmVerses",
          "note": "Verses from Psalms 140, 141, 129, 116 read until stichera begin"
        },
        {
          "id": "stichera-lord-i-call",
          "type": "variable",
          "slot": "stichera-lord-i-call",
          "resolvedBy": "sticheraAssembler",
          "params": {
            "defaultCount": 10,
            "insertionPoint": "betweenPsalmVerses"
          },
          "sources": ["octoechos", "menaion", "triodion", "pentecostarion"]
        }
      ]
    },

    {
      "id": "entrance",
      "label": "The Entrance",
      "note": "At Great Vespers only. Deacon stands before the open Holy Doors.",
      "blocks": [
        {
          "id": "entrance-wisdom",
          "type": "fixed",
          "speaker": "deacon",
          "textKey": "entrance.wisdom"
        }
      ]
    },

    {
      "id": "gladsome-light",
      "label": "Gladsome Light",
      "blocks": [
        {
          "id": "gladsome-light-hymn",
          "type": "fixed",
          "speaker": "choir",
          "textKey": "gladsome-light"
        }
      ]
    },

    {
      "id": "prokeimenon",
      "label": "Evening Prokeimenon",
      "note": "Priest at high place (Great Vespers). Deacon exclaims 'Let us attend', priest 'Peace be unto all', deacon announces tone.",
      "blocks": [
        {
          "id": "prokeimenon-intro",
          "type": "fixed",
          "speaker": "priest",
          "textKey": "prokeimenon.intro"
        },
        {
          "id": "prokeimenon-text",
          "type": "variable",
          "slot": "prokeimenon",
          "resolvedBy": "prokeimenonResolver",
          "params": {
            "sources": ["weekday", "greatFeast", "soulSaturday"]
          }
        }
      ]
    },

    {
      "id": "old-testament-lessons",
      "label": "Old Testament Lessons",
      "note": "Great Vespers only, when appointed by Menaion or Pentecostarion. Three lessons typical.",
      "blocks": [
        {
          "id": "ot-lessons",
          "type": "variable",
          "slot": "ot-lessons",
          "resolvedBy": "lessonsResolver",
          "optional": true,
          "params": {
            "source": "menaion-or-pentecostarion"
          }
        }
      ]
    },

    {
      "id": "augmented-litany",
      "label": "Litany of Fervent Supplication",
      "note": "Begins during or after third lesson at Great Vespers",
      "blocks": [
        {
          "id": "augmented-litany-body",
          "type": "fixed",
          "speaker": "deacon",
          "textKey": "litanies.augmented"
        },
        {
          "id": "augmented-litany-exclamation",
          "type": "fixed",
          "speaker": "priest",
          "textKey": "litanies.augmented.exclamation"
        }
      ]
    },

    {
      "id": "vouchsafe",
      "label": "Vouchsafe, O Lord",
