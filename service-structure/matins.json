        {
          "id": "canon-ode-1",
          "type": "variable",
          "slot": "canon-ode-1",
          "resolvedBy": "canonResolver",
          "sources": ["octoechos", "menaion", "triodion"],
          "note": "Ode 1: irmos + troparia + katavasia"
        },
        {
          "id": "canon-ode-3",
          "type": "variable",
          "slot": "canon-ode-3",
          "resolvedBy": "canonResolver",
          "sources": ["octoechos", "menaion", "triodion"],
