    {
      "id": "litya",
      "label": "The Litya",
      "note": "All-Night Vigil only. Procession to the narthex. Litya stichera (from Menaion/Pentecostarion), then Litany of Supplication.",
      "condition": "serviceType === 'all-night-vigil'",
      "optional": true,
      "blocks": [
        {
          "id": "litya-stichera",
          "type": "variable",
          "slot": "litya-stichera",
          "resolvedBy": "sticheraAssembler",
          "sources": ["menaion", "triodion", "pentecostarion"]
        },
        {
          "id": "litya-litany",
          "type": "fixed",
          "speaker": "deacon",
          "textKey": "litanies.litya"
        },
        {
          "id": "litya-litany-exclamation",
