      "blocks": [
        {
          "id": "god-is-the-lord-refrain",
          "type": "variable",
          "slot": "god-is-the-lord",
          "resolvedBy": "godIsTheLordResolver",
          "note": "Refrain sung in the tone of the first troparion. Four psalm verses from Ps 117(118)."
        }
