    {
      "id": "six-psalms",
      "label": "The Six Psalms",
      "note": "Psalms 3, 37(38), 62(63), 87(88), 102(103), 142(143). Read in a darkened church. Absolute silence required — no movement, no censing until the midpoint. The reader begins with the doxology 'Glory to God in the highest' thrice.",
      "blocks": [
        {
          "id": "six-psalms-intro",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "sixPsalms.intro"
        },
        {
          "id": "six-psalms-first-three",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "sixPsalms.firstThree",
          "note": "Psalms 3, 37(38), 62(63). Read from psalter.json."
        },
        {
          "id": "six-psalms-mid-glory",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "sixPsalms.midGlory"
        },
        {
          "id": "six-psalms-last-three",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "sixPsalms.lastThree",
          "note": "Psalms 87(88), 102(103), 142(143). Priest reads the Morning Prayers silently during these."
        }
      ]
    },

    {
      "id": "great-litany",
