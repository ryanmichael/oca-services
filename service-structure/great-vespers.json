        },
        {
          "id": "glory-now-short-5",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "doxology.gloryNow"
        },
        {
          "id": "our-father-2",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "prayers.ourFather"
        },
        {
          "id": "kingdom-exclamation-2",
          "type": "fixed",
