          "textKey": "doxology.gloryNow"
        },
        {
          "id": "most-holy-trinity",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "prayers.mostHolyTrinity"
        },
        {
          "id": "lord-have-mercy-3",
          "type": "fixed",
          "speaker": "reader",
          "textKey": "responses.lordHaveMercyThrice"
        },
        {
          "id": "glory-now-short-2",
          "type": "fixed",
