    {
      "id": "aposticha",
      "label": "Aposticha",
      "note": "Choir sings appointed Aposticha. On Saturdays at Great Vespers, specific psalm verses are used.",
      "blocks": [
        {
          "id": "aposticha-verses",
          "type": "variable",
          "slot": "aposticha",
          "resolvedBy": "apostichaAssembler",
          "params": {
            "verseSource": {
              "saturday": "aposticha.saturdayVerses",
              "other": "aposticha.defaultVerses"
