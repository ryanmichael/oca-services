    {
      "id": "troparia-after-god-is-the-lord",
      "label": "Troparia",
      "note": "Resurrectional troparion (Sunday) or saint's troparion (weekday), with Glory/Now theotokion. Same tropariaAssembler pattern as Vespers.",
      "blocks": [
        {
          "id": "troparia-matins",
          "type": "variable",
          "slot": "troparia",
          "resolvedBy": "tropariaAssembler",
          "sources": ["octoechos", "menaion", "triodion"],
          "structure": [
            { "slot": "troparion-1", "label": null },
            { "slot": "glory", "textKey": "doxology.gloryOnly", "optional": true },
            { "slot": "troparion-2", "optional": true },
            { "slot": "now", "textKey": "doxology.nowOnly", "optional": true },
            { "slot": "theotokion", "optional": true }
          ]
        }
      ]
    },

