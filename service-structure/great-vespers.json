    {
      "id": "troparia",
      "label": "Troparia",
      "note": "Choir sings appointed Troparia for the day/feast",
      "blocks": [
        {
          "id": "troparion-of-day",
          "type": "variable",
          "slot": "troparia",
          "resolvedBy": "tropariaAssembler",
          "sources": ["octoechos", "menaion", "triodion"],
          "structure": [
            { "slot": "troparion-1", "label": null },
            { "slot": "glory", "textKey": "doxology.gloryOnly", "optional": true },
            { "slot": "troparion-2-or-kontakion", "optional": true },
            { "slot": "now", "textKey": "doxology.nowOnly", "optional": true },
            { "slot": "theotokion", "optional": true }
          ]
        }
      ]
    },

    {
      "id": "blessing-of-bread",
      "label": "Blessing of Bread, Wheat, Wine, and Oil",
      "note": "All-Night Vigil only. Follows Dismissal Troparia.",
      "condition": "serviceType === 'all-night-vigil'",
      "optional": true,
      "blocks": [
        {
          "id": "blessing-of-bread-prayer",
          "type": "fixed",
          "speaker": "priest",
          "textKey": "prayers.blessingOfBread"
        },
        {
